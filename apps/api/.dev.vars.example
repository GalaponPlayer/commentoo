# Local Worker secrets for `wrangler dev`. Copy to `.dev.vars` (gitignored).
# Neon connection string (a dev branch is fine).
DATABASE_URL=postgresql://user:password@host/database
# Secret used to sign/verify anonymous participant tokens (HS256).
# Generate one with: openssl rand -base64 48
PARTICIPANT_TOKEN_SECRET=replace-me-with-a-long-random-string
